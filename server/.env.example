PORT=5000
NODE_ENV=development

# ─── Base de données PostgreSQL (Supabase en prod) ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=bk_engineering

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Supabase Storage (images) ───────────────────────────────────────────────
# Récupérer dans : Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key
SUPABASE_BUCKET=bk-engineering

# ─── CORS ────────────────────────────────────────────────────────────────────
CLIENT_URL=https://bk-engineering-group.vercel.app

# ─── Email (optionnel) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
CONTACT_EMAIL=patikanblaiskeem@gmail.com
